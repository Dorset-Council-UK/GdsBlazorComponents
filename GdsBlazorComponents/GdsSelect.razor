@typeparam T
@inherits InputSelect<T>

<select id="@Id" class="@ComponentClass" @attributes="AdditionalAttributes" @bind="CurrentValueAsString" @bind:event="onchange">
    @ChildContent
</select>

@code {
    [CascadingParameter]
    private string? CascadedId { get; set; }

    [Parameter]
    public string? Id { get; set; }

    protected override void OnParametersSet()
    {
        Id ??= CascadedId;
        base.OnParametersSet();
    }
    private string ComponentClass => $"govuk-select {CssClass}".Trim();
}