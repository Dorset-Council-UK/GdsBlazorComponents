@typeparam T
@inherits InputSelect<T>

<select id="@Id" class="@_class" @attributes="AdditionalAttributes" @bind="CurrentValueAsString" @bind:event="onchange">
    @ChildContent
</select>

@code {
    [CascadingParameter]
    private string? CascadedId { get; set; }

    [Parameter]
    public string? Id { get; set; }
    
    [Parameter]
    public string? AdditionalCssClasses { get; set; }

    private string? _class;

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        Id ??= CascadedId;
        _class = new CssClassBuilder("govuk-select")
            .Add(CssClass)
            .Add(AdditionalCssClasses)
            .Build();
    }
}