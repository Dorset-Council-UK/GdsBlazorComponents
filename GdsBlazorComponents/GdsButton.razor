<button type="@(IsSubmit ? "submit" : "button")"
    @attributes="@AdditionalAttributes"
    class="@ComponentClass"
    data-module="govuk-button"
    data-prevent-double-click=@(PreventDoubleClick ? "true": null)
    @onclick="@(IsSubmit ? default : OnClick)">
    @Text
</button>

@code {
    [Parameter]
    public string? Text { get; set; } = "Continue";

    [Parameter]
    public bool PreventDoubleClick { get; set; } = false;

    [Parameter]
    public bool IsSubmit { get; set; } = true;

    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    private string BaseClass = "govuk-button";

    [Obsolete("Use AdditionalCssClasses instead.")]
    [Parameter]
    public string? CssClass { get; set; }

    [Parameter]
    public string? AdditionalCssClasses { get; set; }

    private string ComponentClass => $"{BaseClass} {AdditionalCssClasses}";

    // Use attribute splatting on non-input components and inheritance on others.
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }
}