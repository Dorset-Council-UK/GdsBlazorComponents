@if (IsSubmit){
    <button type="submit"
        @attributes="GetButtonAttributes()" 
        data-module="govuk-button">
        @Text
    </button>
} else
{
    <button type="button"
        @attributes="GetButtonAttributes()" 
        data-module="govuk-button" 
        @onclick="OnClick">
        @Text
    </button>
}

@code{
    [Parameter]
    public string? Text { get; set; } = "Continue";

    [Parameter]
    public bool Disabled { get; set; } = false;

    [Parameter]
    public bool PreventDoubleClick { get; set; } = false;

    [Parameter]
    public bool IsSubmit { get; set; } = true;

    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private Dictionary<string, object> GetButtonAttributes()
    {
        var attributes = new Dictionary<string, object>(AdditionalAttributes ?? new Dictionary<string, object>());

        // Handle class attribute - ensure govuk-button is always present
        if (attributes.ContainsKey("class"))
        {
            var existingClass = attributes["class"]?.ToString() ?? string.Empty;
            if (!existingClass.Contains("govuk-button "))
            {
                attributes["class"] = $"govuk-button {existingClass}".Trim();
            }
        }
        else
        {
            attributes["class"] = "govuk-button";
        }

        if (PreventDoubleClick)
        {
            attributes["data-prevent-double-click"] = "true";
        }

        if (Disabled)
        {
            attributes["disabled"] = true;
            attributes["aria-disabled"] = "true";
        }

        return attributes;
    }
}