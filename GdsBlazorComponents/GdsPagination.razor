<nav class="@_classes" aria-label="Pagination" @attributes="@AdditionalAttributes">
    <CascadingValue Name="GdsPagination.BlockStyle" Value="@BlockStyle">
        <CascadingValue Name="GdsPagination.CurrentPage" Value="@CurrentPage">
            @if (CurrentPage > 1)
            {
                <GdsPaginationPrevious Href="@_previousHref" OnPrevious="@_onPrevious" Label="@PreviousLabel" />
            }

            @if (!BlockStyle && _pageNumbers.Count > 0)
            {
                <ul class="govuk-pagination__list">
                    @foreach (var pageNumber in _pageNumbers)
                    {
                        if (pageNumber is null)
                        {
                            <GdsPaginationItem />
                        }
                        else
                        {
                            <GdsPaginationItem Href="@GetPageHref(pageNumber.Value)" PageNumber="@pageNumber.Value" OnPageChanged="@_onItemPageChanged" />
                        }
                    }
                </ul>
            }

            @if (CurrentPage < TotalPages)
            {
                <GdsPaginationNext Href="@_nextHref" OnNext="@_onNext" Label="@NextLabel" />
            }
        </CascadingValue>
    </CascadingValue>
</nav>

@code {
    [Parameter]
    public bool BlockStyle { get; set; }

    [Parameter]
    public int CurrentPage { get; set; } = 1;

    [Parameter]
    public EventCallback<int> OnPageChanged { get; set; }

    [Parameter]
    public string? PreviousLabel { get; set; }

    [Parameter]
    public string? NextLabel { get; set; }

    [Parameter]
    public int TotalPages { get; set; } = 1;

    /// <summary>
    /// Example: HrefGenerator="@(pageNumber => $"search?page={pageNumber}")"
    /// </summary>
    [Parameter]
    public Func<int, string>? HrefGenerator { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string? _classes;
    private string? _previousHref;
    private string? _nextHref;
    private List<int?> _pageNumbers = [];

    private EventCallback<int> _onItemPageChanged;
    private EventCallback<MouseEventArgs> _onPrevious;
    private EventCallback<MouseEventArgs> _onNext;

    protected override void OnParametersSet()
    {
        _classes = BlockStyle ? "govuk-pagination govuk-pagination--block" : "govuk-pagination";
        _pageNumbers = CalculatePageNumbers();
        _previousHref = HrefGenerator?.Invoke(PreviousPageNumber);
        _nextHref = HrefGenerator?.Invoke(NextPageNumber);

        if (OnPageChanged.HasDelegate)
        {
            _onItemPageChanged = EventCallback.Factory.Create<int>(this, HandlePageChanged);
            _onPrevious = EventCallback.Factory.Create<MouseEventArgs>(this, HandlePrevious);
            _onNext = EventCallback.Factory.Create<MouseEventArgs>(this, HandleNext);
        }
        else
        {
            _onItemPageChanged = default;
            _onPrevious = default;
            _onNext = default;
        }
    }

    private int PreviousPageNumber => Math.Max(1, CurrentPage - 1);
    private int NextPageNumber => Math.Min(TotalPages, CurrentPage + 1);
    private string? GetPageHref(int pageNumber) => HrefGenerator?.Invoke(pageNumber);

    private Task HandlePrevious(MouseEventArgs args) => HandlePageChanged(PreviousPageNumber);
    private Task HandleNext(MouseEventArgs args) => HandlePageChanged(NextPageNumber);
    private Task HandlePageChanged(int pageNumber) => OnPageChanged.InvokeAsync(pageNumber);

    /// <summary>
    /// Works out which page numbers to display, inserting <see langword="null" /> where ellipses should appear,
    /// following the <see href="https://design-system.service.gov.uk/components/pagination/">GDS pagination guidelines</see>
    /// </summary>
    /// <returns>
    /// A list of page numbers, with <see langword="null" /> representing an ellipsis placeholder.
    /// </returns>
    private List<int?> CalculatePageNumbers()
    {
        var items = new List<int?>();

        // Block style doesn't show page numbers
        if (BlockStyle) return items;

        if (TotalPages <= 1) return items;

        // Always show page 1
        items.Add(1);

        // Ellipsis before current page range
        if (CurrentPage > 3)
        {
            items.Add(null); // ellipsis
        }

        // Pages around current
        var start = Math.Max(2, CurrentPage - 1);
        var end = Math.Min(TotalPages - 1, CurrentPage + 1);

        for (var i = start; i <= end; i++)
        {
            if (i != 1 && i != TotalPages)
            {
                items.Add(i);
            }
        }

        // Ellipsis after current page range
        if (CurrentPage < TotalPages - 2)
        {
            items.Add(null); // ellipsis
        }

        // Always show last page
        if (TotalPages > 1)
        {
            items.Add(TotalPages);
        }

        return items;
    }
}