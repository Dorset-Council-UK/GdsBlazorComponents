<div class="govuk-phase-banner" @attributes="@AdditionalAttributes">
    <p class="govuk-phase-banner__content">
        @if (Phase != Phases.None)
        {
            <GdsTag Text="@Phase.ToString()" AdditionalCssClasses="govuk-phase-banner__content__tag" />
        }
        @if (FeedbackLink != null)
        {
            <span class="govuk-phase-banner__text">
                This is a new service – your <a class="govuk-link" href="@FeedbackLink">@FeedbackText</a> will help us to improve it.
            </span>
        }
        else
        {
            <span class="govuk-phase-banner__text">
                This is a new service – your @FeedbackText will help us to improve it.
            </span>
        }
    </p>
</div>

@code {
    public enum Phases
    {
        None,
        Alpha,
        Beta,
        New,
        Development
    }

    [Parameter]
    public Phases Phase { get; set; } = Phases.None;

    [Parameter]
    public Uri? FeedbackLink { get; set; }

    [Parameter]
    public string FeedbackText { get; set; } = "feedback";

    // Use attribute splatting on non-input components and inheritance on others.
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }
}