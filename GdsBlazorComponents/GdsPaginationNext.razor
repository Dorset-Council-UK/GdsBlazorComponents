<div class="govuk-pagination__next" @attributes="@AdditionalAttributes">
    <a class="govuk-link govuk-pagination__link" href="@Href" rel="next" @onclick="HandleNext" @onclick:preventDefault="OnNext.HasDelegate">
        @if (BlockStyle)
        {
            NextArrow();
        }
        <span class="govuk-pagination__link-title">
            @Title<span class="govuk-visually-hidden"> page</span>
        </span>
        @if (BlockStyle && !string.IsNullOrWhiteSpace(Label))
        {
            <span class="govuk-visually-hidden">:</span>
            <span class="govuk-pagination__link-label">@Label</span>
        }
        @if (!BlockStyle)
        {
            NextArrow();
        }
    </a>
</div>

@code {
    [CascadingParameter]
    public bool BlockStyle { get; set; }

    [Parameter]
    public string? Href { get; set; } = "#";

    [Parameter]
    public string? Label { get; set; }

    [Parameter]
    public string Title { get; set; } = "Next";

    [Parameter]
    public EventCallback<MouseEventArgs> OnNext { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private async Task HandleNext(MouseEventArgs args)
    {
        if (OnNext.HasDelegate)
        {
            await OnNext.InvokeAsync(args);
        }
    }

    private RenderFragment NextArrow()
    {
        return @<svg class="govuk-pagination__icon govuk-pagination__icon--next" xmlns="http://www.w3.org/2000/svg" height="13" width="15" aria-hidden="true" focusable="false" viewBox="0 0 15 13">
            <path d="m8.107-0.0078125-1.4136 1.414 4.2926 4.293h-12.986v2h12.896l-4.1855 3.9766 1.377 1.4492 6.7441-6.4062-6.7246-6.7266z"></path>
        </svg>;
    }
}