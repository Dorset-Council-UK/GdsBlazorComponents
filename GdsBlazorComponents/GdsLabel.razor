<label for="@For" class="@LabelCssClass" @attributes="@AdditionalAttributes">@Text</label>

@code {
    [CascadingParameter]
    private string? CascadedId { get; set; }

    [Parameter]
    public string? For { get; set; }

    [Parameter]
    public string Text { get; set; } = "";

    [Parameter]
    public string CssClass { get; set; } = "govuk-label";

    [Parameter]
    public string? AdditionalCssClasses { get; set; }

    private string LabelCssClass => $"{CssClass} {AdditionalCssClasses}";

    // Use attribute splatting on non-input components and inheritance on others.
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    protected override void OnInitialized()
    {
        if (For == null)
        {
            For = CascadedId;
        }
    }
}
