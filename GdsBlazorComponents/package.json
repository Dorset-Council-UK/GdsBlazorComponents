{
  "name": "gds-blazor-components",
  "version": "3.2.0",
  "description": "Blazor components styled to match GOV.UK Design System.",
  "repository": "https://github.com/Dorset-Council-UK/GdsBlazorComponents",
  "author": "Dorset Council",
  "license": "MIT",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "webpack --node-env production --config webpack.prod.js",
    "build:dev": "webpack --node-env development --config webpack.dev.js",
    "watch": "webpack --config webpack.dev.js --watch",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "outdated": "npm outdated"
  },
  "dependencies": {
    "@types/govuk-frontend": "5.11.0",
    "govuk-frontend": "5.14.0"
  },
  "devDependencies": {
    "@types/node": "24.12.2",
    "css-loader": "7.1.4",
    "mini-css-extract-plugin": "2.10.2",
    "sass": "1.99.0",
    "sass-loader": "16.0.7",
    "ts-loader": "9.5.7",
    "typescript": "5.9.3",
    "webpack": "5.106.2",
    "webpack-cli": "6.0.1",
    "webpack-merge": "6.0.1"
  },
  "-vs-binding": {
    "ProjectOpened": [
      "watch",
      "build:dev"
    ],
    "BeforeBuild": [
      "build:dev"
    ]
  }
}
