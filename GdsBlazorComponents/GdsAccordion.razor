<div class="@_class" data-module="govuk-accordion" id="@Id" @attributes="@AdditionalAttributes">
    <CascadingValue Value="@context" IsFixed="true">
        @ChildContent
    </CascadingValue>
</div>

@code {
    [Parameter, EditorRequired]
    public required string Id { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string? AdditionalCssClasses { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private readonly AccordionContext context = new();
    private string? _class;

    protected override void OnInitialized()
    {
        context.Reset(Id);
    }

    protected override void OnParametersSet()
    {
        _class = new CssClassBuilder("govuk-accordion")
            .Add(AdditionalCssClasses)
            .Build();
    }

    public class AccordionContext
    {
        private int index;
        public string AccordionId { get; private set; } = string.Empty;

        public int NextIndex() => ++index; // 1-based: first section gets 1, not 0

        public void Reset(string accordionId)
        {
            AccordionId = accordionId;
            index = 0;
        }
    }
}