<a href="@Href" class="@_class" @onclick="HandleClick" @onclick:preventDefault="PreventDefault" @attributes="AdditionalAttributes">
    @ChildContent
</a>

@code {
    [Parameter, EditorRequired]
    public required RenderFragment ChildContent { get; set; }

    [Parameter]
    public string? AdditionalCssClasses { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    [Parameter, EditorRequired]
    public required string Href { get; set; }

    [Parameter]
    public bool NoVisitedState { get; set; }

    [Parameter]
    public bool Inverse { get; set; }

    [Parameter]
    public bool NoUnderline { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    [Parameter]
    public bool PreventDefault { get; set; }

    private string? _class;

    protected override void OnParametersSet()
    {
        _class = new CssClassBuilder("govuk-link")
            .AddIf(NoVisitedState, "govuk-link--no-visited-state")
            .AddIf(Inverse, "govuk-link--inverse")
            .AddIf(NoUnderline, "govuk-link--no-underline")
            .Add(AdditionalCssClasses)
            .Build();
    }

    private async Task HandleClick(MouseEventArgs args)
    {
        if (OnClick.HasDelegate)
        {
            await OnClick.InvokeAsync(args);
        }
    }
}
